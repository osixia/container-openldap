OPENLDAP_CONF_DIR="/etc/openldap/slapd.d"
OPENLDAP_DATA_DIR="/var/lib/openldap/openldap-data"

OPENLDAP_BACKUP_DIR="/var/lib/openldap/openldap-backups"

OPENLDAP_MODULES_DIR="/usr/lib/openldap"
OPENLDAP_SCHEMAS_DIR="/etc/openldap/schema"

OPENLDAP_CUSTOM_MODULES_DIR="/container/services/openldap/assets/module"
OPENLDAP_CUSTOM_SCHEMAS_DIR="/container/services/openldap/assets/schema"

OPENLDAP_NOFILE="65536"
OPENLDAP_DEBUG_LEVEL="256"
