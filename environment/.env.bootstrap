OPENLDAP_BOOTSTRAP_ORGANIZATION="Example Org"
OPENLDAP_BOOTSTRAP_SUFFIX="dc=example,dc=org"

OPENLDAP_BOOTSTRAP_MODULES="back_mdb.so argon2.so ppolicy.so refint.so syncprov.so"
OPENLDAP_BOOTSTRAP_SCHEMAS="core.ldif cosine.ldif inetorgperson.ldif rfc2307bis.ldif"

OPENLDAP_BOOTSTRAP_CONFIG_ROOT_DN="cn=admin,cn=config"
OPENLDAP_BOOTSTRAP_CONFIG_ROOT_PASSWORD_HASHED=""

OPENLDAP_BOOTSTRAP_CONFIG_DATABASE_MAX_SIZE="1073741824"

OPENLDAP_BOOTSTRAP_DATABASE_ROOT_DN="cn=admin,${OPENLDAP_BOOTSTRAP_SUFFIX}"
OPENLDAP_BOOTSTRAP_DATABASE_ROOT_PASSWORD_HASHED=""

OPENLDAP_BOOTSTRAP_DATABASE_READONLY=false
OPENLDAP_BOOTSTRAP_DATABASE_READONLY_DN="cn=readonly,${OPENLDAP_BOOTSTRAP_SUFFIX}"
OPENLDAP_BOOTSTRAP_DATABASE_READONLY_PASSWORD_HASHED=""

OPENLDAP_BOOTSTRAP_MONITOR_ENABLED=false

OPENLDAP_BOOTSTRAP_MONITOR_READONLY=false
OPENLDAP_BOOTSTRAP_MONITOR_READONLY_DN="cn=readonly-monitor,${OPENLDAP_BOOTSTRAP_SUFFIX}"
OPENLDAP_BOOTSTRAP_MONITOR_READONLY_PASSWORD_HASHED=""

OPENLDAP_BOOTSTRAP_TLS=false
OPENLDAP_BOOTSTRAP_TLS_CERT="/container/services/openldap/assets/certs/cert.crt"
OPENLDAP_BOOTSTRAP_TLS_CERT_KEY="/container/services/openldap/assets/certs/cert.key"
OPENLDAP_BOOTSTRAP_TLS_CA_CERT="/container/services/openldap/assets/certs/ca.crt"
OPENLDAP_BOOTSTRAP_TLS_VERIFY_CLIENT="allow"
OPENLDAP_BOOTSTRAP_TLS_PROTOCOL_MIN="3.3"

OPENLDAP_BOOTSTRAP_TLS_REQUIRED=false

OPENLDAP_BOOTSTRAP_REPLICATION=false
OPENLDAP_BOOTSTRAP_REPLICATION_HOSTS="ldap://ldap1.example.org:3890 ldap://ldap2.example.org:3890" # 2 hosts required, in the same order on both LDAP servers

OPENLDAP_BOOTSTRAP_REPLICATION_SYNCPROV_CHECKPOINT="100 10"

OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_READONLY_DN="cn=config-replicator,${OPENLDAP_BOOTSTRAP_SUFFIX}"
OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_READONLY_PASSWORD=""

OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_SYNC_REPL_TEMPLATE="rid=\${OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_SYNC_REPL_RID} provider=\${OPENLDAP_BOOTSTRAP_REPLICATION_SYNC_REPL_PROVIDER} bindmethod=simple binddn=\"\${OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_READONLY_DN}\" credentials=\${OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_READONLY_PASSWORD} searchbase=\"cn=config\" type=refreshAndPersist retry=\"5 5 60 +\" timeout=3"
OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_LIMITS="dn.exact=\"${OPENLDAP_BOOTSTRAP_REPLICATION_CONFIG_READONLY_DN}\" time.soft=unlimited time.hard=unlimited size.soft=unlimited size.hard=unlimited"

OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_READONLY_DN="cn=data-replicator,${OPENLDAP_BOOTSTRAP_SUFFIX}"
OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_READONLY_PASSWORD=""

OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_SYNC_REPL_TEMPLATE="rid=\${OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_SYNC_REPL_RID} provider=\${OPENLDAP_BOOTSTRAP_REPLICATION_SYNC_REPL_PROVIDER} bindmethod=simple binddn=\"\${OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_READONLY_DN}\" credentials=\${OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_READONLY_PASSWORD} searchbase=\"\${OPENLDAP_BOOTSTRAP_SUFFIX}\" schemachecking=on type=refreshAndPersist retry=\"5 5 60 +\" timeout=3"
OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_LIMITS="dn.exact=\"${OPENLDAP_BOOTSTRAP_REPLICATION_DATABASE_READONLY_DN}\" time.soft=unlimited time.hard=unlimited size.soft=unlimited size.hard=unlimited"

OPENLDAP_BOOTSTRAP_REPLICATION_TLS="${OPENLDAP_BOOTSTRAP_TLS_REQUIRED}"
OPENLDAP_BOOTSTRAP_REPLICATION_TLS_SYNC_REPL="starttls=critical tls_reqcert=demand"

OPENLDAP_BOOTSTRAP_LDIF_CONFIG_DIR="/container/services/openldap-bootstrap/assets/ldif/config"
OPENLDAP_BOOTSTRAP_LDIF_DATA_DIR="/container/services/openldap-bootstrap/assets/ldif/data"
OPENLDAP_BOOTSTRAP_SCRIPTS_DIR="/container/services/openldap-bootstrap/assets/scripts"
